# YouTube Music to Plex environment configuration
# Copy this file to .env.local for local development.

# Server configuration
PORT=9030
NODE_ENV=production

# Google OAuth configuration
# Use a Web application OAuth client in Google Cloud.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
# Local redirect example:
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:9030/api/youtube-music/token

# Internal YouTube Music service
YTMUSIC_SERVICE_URL=http://localhost:3020

# Tidal API configuration (optional)
TIDAL_API_CLIENT_ID=your_tidal_client_id_here
TIDAL_API_CLIENT_SECRET=your_tidal_client_secret_here

# Security
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# Plex configuration
PLEX_APP_ID=eXf+f9ktw3CZ8i45OY468WxriOCtoFxuNPzVeDcAwfw=

# MQTT configuration (optional)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=youtube_music_to_plex

# Lidarr integration (optional)
LIDARR_API_KEY=your_lidarr_api_key_here

# SLSKD integration (optional)
SLSKD_API_KEY=your_slskd_api_key_here
